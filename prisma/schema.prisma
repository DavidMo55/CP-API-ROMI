generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CodigoPostal {
  id              Int      @id @default(autoincrement())
  d_codigo        String
  d_asenta        String
  d_tipo_asenta   String
  D_mnpio         String
  d_estado        String
  d_ciudad        String?
  d_zona          String?

  @@index([d_codigo])
}